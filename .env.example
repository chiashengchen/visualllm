# Copy to .env and fill in. The pipeline reads these via pipeline/config.py.
# Default stack: Deepgram STT -> OpenRouter LLM -> CosyVoice TTS -> MuseTalk avatar
# (all local except STT/LLM). ElevenLabs/Deepgram TTS and Ditto avatar are fallback switches.

# ---- Language + latency target -------------------------------------------
LANGUAGE=en                    # en | zh | th  (zh = Mandarin / zh-TW)
TTFO_TARGET_SECONDS=8

# ---- Product mode --------------------------------------------------------
# AVATAR selects the face renderer:
#   musetalk = server-side GPU mouth-region talking-head (default; `musetalk` conda
#              env + server; no warmup, sharper lips, only the mouth animates)
#   ditto    = server-side GPU full-face talking-head (`ditto` conda env; ~2.2s warmup)
#   none     = audio-only; the CLIENT renders the 3D face (no GPU/conda needed --
#              the validation-sprint / unit-economics path)
AVATAR=musetalk                # musetalk | ditto | none
# CHARACTER_MODE=1 swaps the flat voice-assistant prompt for the in-character
# Thai persona ("น้องเอวา") used by the live-visual validation demo. Pair with
# LANGUAGE=th; the leading [emotion] tag is stripped before TTS (never spoken).
CHARACTER_MODE=0               # 0 | 1
# ECHO_GUARD=1 mutes the mic while the bot speaks (half-duplex) so the avatar's
# own voice can't trigger a barge-in that cuts the render mid-turn. Set 0 to allow
# interrupting the bot (then rely on headphones / OS echo cancellation).
ECHO_GUARD=1                   # 1 | 0

# ---- STT: Deepgram (console.deepgram.com) --------------------------------
DEEPGRAM_API_KEY=

# ---- LLM: OpenRouter (one key, any model via OPENROUTER_MODEL) ------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# ---- TTS provider switch -------------------------------------------------
# cosyvoice (default) = local CosyVoice2-0.5B streaming server (female zero-shot
#   voice); run it separately in the `tts` conda env on port 8001 (see the
#   cosyvoice-local-tts repo). elevenlabs / deepgram are cloud fallbacks.
TTS_PROVIDER=cosyvoice          # cosyvoice | elevenlabs | deepgram
COSYVOICE_URL=http://localhost:8001
COSYVOICE_VOICE=weather         # the server's registered female zero-shot speaker
# COSYVOICE_SAMPLE_RATE=24000   # CosyVoice2 native rate (Pipecat resamples to 16k)

# ---- TTS fallback: ElevenLabs (elevenlabs.io -> API key + a voice ID) -----
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# flash_v2_5 = low latency + multilingual (zh-TW). multilingual_v2 = warmer/slower.
ELEVENLABS_MODEL=eleven_flash_v2_5

# ---- Avatar: local lip-sync server ---------------------------------------
AVATAR_URL=http://localhost:8002
AVATAR_REF=assets/avatar_female.png   # portrait (image OR video) read by the avatar server
# MuseTalk output knobs (the active engine when AVATAR=musetalk):
# MUSETALK_FPS=20                # push rate; main.py couples video_out_framerate to it
# MUSETALK_SIZE=512              # square output px (the server resizes to this); smaller = less WAN bandwidth
# --- MuseTalk A/V sync ---
# MUSETALK_SYNC_MODE=steady      # steady (default) = VIDEO-MASTER: synced start, voice held + released locked
#                                  to rendered frames. The old steady "screech" is FIXED (musetalk_video
#                                  _align_even whole-sample guard + main.py BOT_VAD_STOP_FALLBACK_SECS raise).
#                                  Tradeoff: under a long render stall the voice briefly pauses then resumes clean.
#                                  live = AUDIO-MASTER: voice always real-time, lips best-effort (~0.75s trail),
#                                  never pauses -- switch to it if the steady pause is worse than the lip trail.
# MUSETALK_SYNC_MAX_LAG=0.5      # live: stop feeding the server when lips fall this far behind -> they skip to stay current
# MUSETALK_SYNC_LEAD_S=0.0       # (steady/prerender) lip-offset trim: +ve releases voice earlier, -ve if lips lead
# MUSETALK_SYNC_FALLBACK_S=10    # (steady/prerender) if no video markers within this, forward voice unsynced
# Smoothness vs latency (Ditto renders in ~2.8s bursts at the realtime edge):
# the server primes a jitter buffer before playing, then CLOCKS the client's
# voice to the real frames it has rendered (video_start/video_clock/video_end
# markers) -- so the voice waits when the render stalls and never drifts ahead.
# DITTO_LEAD_FRAMES     server: frames to buffer before playback (25 ~= 1s @25fps)
# DITTO_IDLE_GRACE      server: seconds of empty queue before returning to neutral
# DITTO_SYNC_LEAD_S     client: small constant lip lead; raise/lower to align lips
# DITTO_SYNC_FALLBACK_S client: if no markers arrive within this, play voice unsynced
# --- DITTO_TRT: TensorRT-FP16 acceleration (default ON) -------------------
# The single biggest speed lever on this Blackwell (RTX 50-series) GPU. Ditto's heavy,
# plugin-free models (decoder/stitch/appearance) are swapped for FP16 TensorRT engines
# built FOR THIS CARD by `python -m local_services.ditto_server.build_trt` (a one-time,
# no-compiler step -- engines are GPU-arch-specific and cached in checkpoints/
# ditto_trt_blackwell/). The decoder drops ~41ms -> ~14ms, raising the measured render
# rate from ~8 to ~16 real fps -- SAME photoreal visual (each engine is numerically
# validated vs fp32 before use). warp + diffusion + aux models stay PyTorch (warp needs
# the GridSample3D plugin = a compiler). Set DITTO_TRT=0 for the pure-PyTorch fallback
# (then also drop DITTO_FPS to 8).
# DITTO_TRT=1
#
# --- DITTO_FPS (frame-dropping) -------------------------------------------
# Output frame rate. Below the native 25 the server drops in-between motion frames BEFORE
# the costly render stages, so the GPU does less work and KEEPS UP in real time. A/V stays
# locked because the voice is frame-clocked to the real video -- lower fps just means
# choppier motion, not desync. WITH DITTO_TRT on, the sustainable rate is ~12-16 fps;
# default is 12 (was 8 before TRT). Use an INTEGER (main.py couples the transport rate to
# it). Lower (8) for more headroom or if DITTO_TRT=0.
# DITTO_FPS=12
#
# DITTO_PRERENDER   1 = COMPUTE-FIRST buffer (default), COMBINED with frame-drop above:
#                   wait until a whole sentence is rendered, then play it with the voice
#                   frame-clocked to it -> the sentence can't lag at the start (video and
#                   voice begin together). Frame-drop keeps the pre-render fast; the silent
#                   end-of-sentence flush is trimmed so the mouth stops when the voice does.
#                   Cost: a ~3-4s render-wait before each short sentence shows. 0 = legacy
#                   live-stream (lower latency, but lips lag the voice at each line's start).
# DITTO_PRERENDER=1
# DITTO_PRERENDER_MAX_FRAMES=250   server: cap the pre-render buffer (~10s) for long lines
# DITTO_LEAD_FRAMES=8              server: output frames buffered before playback starts
# DITTO_IDLE_GRACE=0.8
# DITTO_SYNC_LEAD_S   client lip offset. The render's mouth motion LEADS the audio content
#                   by a small constant (a model look-ahead, ~0.18s at DITTO_OVERLAP=45);
#                   this releases the voice that much earlier to cancel it. Measured by
#                   scripts/avatar_tune.py -- net residual ~0.04s at the defaults. Raise if
#                   lips still lead the voice, lower if they trail.
# DITTO_SYNC_LEAD_S=0.2
# DITTO_SYNC_FALLBACK_S=10.0       client: patience for video markers before giving up sync
#
# --- Secondary tuning. The key signal is real_fps in the logs/ditto.log watchdog (or
#     the dashboard avatar panel): the ACTUAL rendered-frame rate. While speaking it
#     should sit at/above DITTO_FPS -- if it's below, the renderer is behind. ---
# DITTO_STEPS   diffusion sampling steps = MOTION quality (offline default 50). Higher
#               = smoother/more accurate lip+head motion. 25 = good; raise for motion,
#               lower (15) to buy render headroom if real_fps is short.
# DITTO_STEPS=25
# DITTO_OVERLAP the motion diffuser renders once it has (80 - overlap) new audio frames,
#               running a full 80-frame denoise each pass. It ALSO sets how far the mouth
#               motion LEADS the audio (a model look-ahead): wider window = more lead.
#               Measured by scripts/avatar_tune.py: overlap 10 -> mouth leads ~0.40s;
#               overlap 45 -> ~0.18s (cleanest lip tracking). 45 is the DEFAULT because in
#               compute-first mode the extra diffusion passes don't gate playback (we
#               pre-render), so we pick overlap for LIP-SYNC, and 0.18s is cancelled by
#               DITTO_SYNC_LEAD_S=0.2. (In LIVE mode pick a wider window for real_fps:
#               10 -> ~13 fps real / keeps up; 60 -> ~9.5 fps / drifts.)
# DITTO_OVERLAP=45
# DITTO_OVERLAP=10
# DITTO_SIZE    output frame resolution (512). Also buys fps (per-frame decode scales
#               with pixels): 384 or 320 renders faster, at lower sharpness. It is ALSO
#               the dominant lever for a REMOTE/WAN viewer -- a smaller frame needs far
#               less bandwidth, so the video stops starving/stuttering over the link
#               (e.g. 320 for the Thailand->Taiwan path). One value, three places:
#               this is read by the avatar server, the client service, AND the transport
#               (config.avatar_size couples all three) -- never set them apart.
# DITTO_SIZE=512

# ---- Remote / WAN viewing (jitter + bitrate) -----------------------------
# For a far viewer the lag is the NETWORK, not the render. Make the video FIT the link:
# a small frame (DITTO_SIZE above) + a bounded send bitrate, then a modest jitter buffer.
# WEBRTC_VIDEO_BITRATE_MAX  ceiling for aiortc's VP8 encoder (bits/sec). The stock 1.5M
#               ceiling overshoots a jittery consumer link -> the avatar trails the voice.
#               ~600k suits a 320px face. Set 0 to leave aiortc's defaults untouched.
# WEBRTC_VIDEO_BITRATE      start-point bitrate (default 500000); REMB adapts within the band.
# WEBRTC_VIDEO_BITRATE_MIN  floor (default 120000); below aiortc's stock 250k so a bandwidth
#               dip degrades gracefully instead of freezing.
# CLIENT_JITTER_BUFFER_MS   receive-side buffer (default 400; 0 = off). Once the stream fits
#               the link this can be SMALL (~250) -> less lip-lag. Bigger = smoother but the
#               avatar trails further behind the voice.
# WEBRTC_VIDEO_BITRATE_MAX=600000
# WEBRTC_VIDEO_BITRATE=500000
# WEBRTC_VIDEO_BITRATE_MIN=120000
# CLIENT_JITTER_BUFFER_MS=250

# ---- Debug dashboard -----------------------------------------------------
# A live per-stage health view (separate web server, its own port) so you can
# see which stage is working/broken at a glance. Open http://localhost:7861/debug
# while the pipeline runs. Set DEBUG_DASHBOARD=0 to disable (zero pipeline impact).
DEBUG_DASHBOARD=1               # 1 | 0
DEBUG_PORT=7861
