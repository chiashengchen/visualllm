# Copy to .env and fill in. The pipeline reads these via pipeline/config.py.
# Stack: Deepgram STT -> OpenRouter LLM -> CosyVoice TTS -> MuseTalk avatar
# (all local except STT/LLM). ElevenLabs/Deepgram TTS are fallback switches.

# ---- Language + latency target -------------------------------------------
LANGUAGE=en                    # en | zh | th  (zh = Mandarin / zh-TW)
TTFO_TARGET_SECONDS=8

# ---- Product mode --------------------------------------------------------
# ECHO_GUARD: 0 (default) = barge-in, mic always live -> USE HEADPHONES (or OS echo
# cancellation) so the avatar's voice doesn't feed back. 1 = half-duplex mute while the
# bot speaks, but it's BROKEN under the default steady sync (leaves the mic stuck-muted
# after a turn -> voice won't trigger; see docs/PROBLEMS-AND-FIXES.md P11). Use 1 only
# with MUSETALK_SYNC_MODE=live.
ECHO_GUARD=0                   # 0 | 1

# ---- STT: Deepgram (console.deepgram.com) --------------------------------
DEEPGRAM_API_KEY=

# ---- STT provider switch (fallback switch, like TTS_PROVIDER) ------------
#   deepgram = cloud streaming (default, interim partials).
#   sherpa   = local OFFLINE STREAMING (sherpa-onnx zipformer, bilingual zh-en, CPU/~0 VRAM).
#              Drives turn-taking from its own ASR endpoint -> robust to a quiet/RDP mic.
#              Download the model under models/ (see INSTALL.md). RECOMMENDED local option.
#   funasr   = local OFFLINE SEGMENTED (SenseVoice-Small server on :8004; needs the energy-VAD).
STT_PROVIDER=deepgram           # deepgram | sherpa | funasr
SHERPA_MODEL_DIR=models/sherpa-onnx-streaming-zipformer-bilingual-zh-en-2023-02-20
SHERPA_TRADITIONAL=1            # 1 = convert zh output to Traditional (zh-TW) via OpenCC
SHERPA_ENDPOINT_SILENCE=0.5     # pause (s) that ends your turn + fires the query; lower = snappier
# funasr only:
FUNASR_URL=http://localhost:8004
FUNASR_MODEL=iic/SenseVoiceSmall
FUNASR_DEVICE=cpu

# ---- LLM provider switch (fallback switch, like TTS_PROVIDER) ------------
LLM_PROVIDER=openrouter         # openrouter | weather_chain
# weather_chain = dedicated zh weather bot (NCU LangServe); needs LANGUAGE=zh.
WEATHER_CHAIN_URL=http://140.115.54.87:8000/chain/resWeatherChain
WEATHER_CHAIN_MODEL=gemma3:27b

# ---- LLM: OpenRouter (one key, any model via OPENROUTER_MODEL) ------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# ---- Avatar memory harness (fully local, CPU) ----------------------------
# The weather chain is stateless, so the virtual human's growing memory lives
# in our harness: rewrites the query (context engineering) + distills the chat
# after each conversation. CPU-pinned so MuseTalk + CosyVoice keep the GPU.
AVATAR_MEMORY=1                 # 0 = disable memory
AVATAR_MEMORY_DIR=state/avatar_memory
MEMORY_LLM_URL=http://localhost:11434/v1
MEMORY_LLM_MODEL=qwen2.5:3b-cpu  # CPU-pinned; set qwen2.5:3b to use the GPU
MEMORY_LLM_GATED=1              # 0 = rewrite every turn

# ---- TTS provider switch -------------------------------------------------
# cosyvoice (default) = local CosyVoice2-0.5B streaming server (female zero-shot
#   voice); run it separately on port 8001 (see the cosyvoice-local-tts repo).
#   elevenlabs / deepgram are cloud fallbacks (deepgram is English-only).
TTS_PROVIDER=cosyvoice          # cosyvoice | elevenlabs | deepgram
COSYVOICE_URL=http://localhost:8001
COSYVOICE_VOICE=weather         # the server's registered female zero-shot speaker
# COSYVOICE_SAMPLE_RATE=24000   # CosyVoice2 native rate (Pipecat resamples to 16k)

# ---- TTS fallback: ElevenLabs (elevenlabs.io -> API key + a voice ID) -----
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# flash_v2_5 = low latency + multilingual (zh-TW). multilingual_v2 = warmer/slower.
ELEVENLABS_MODEL=eleven_flash_v2_5

# ---- Avatar: local MuseTalk lip-sync server ------------------------------
AVATAR_URL=http://localhost:8002
AVATAR_REF=assets/avatar_female.png   # portrait (image OR video) read by the avatar server
MUSETALK_TRT=1                 # 1 = TensorRT render (UNet+VAE engines in musetalk_server/trt_cache/): ~1.5x faster render, holds A/V sync under shared-GPU contention where PyTorch drifts seconds on long turns. Engines are GPU/driver-specific + gitignored (~1.75GB) -- build with trt_build.py. Any load failure falls back to PyTorch. 0 = PyTorch path.
# MUSETALK_FPS=20                # push rate; main.py couples video_out_framerate to it
# MUSETALK_SIZE=512             # square output px (the server resizes to this); smaller = less WAN bandwidth
# MUSETALK_LEAD_FRAMES=14       # frames primed before playback (LOAD-BEARING: lower starves -> freeze)
# MUSETALK_END_TAIL_FRAMES=10   # ease-out neutral frames after speech (softer mouth-close)
# MUSETALK_FEED_BURST_S=1.0     # burst the first Ns of a turn's audio un-paced so the renderer isn't starved at turn start
# --- MuseTalk A/V sync ---
# MUSETALK_SYNC_MODE=steady      # steady (default) = VIDEO-MASTER: synced start, voice held + released locked
#                                  to rendered frames. The old steady "screech" is FIXED (musetalk_video
#                                  _align_even whole-sample guard + main.py BOT_VAD_STOP_FALLBACK_SECS raise).
#                                  Tradeoff: under a long render stall the voice briefly pauses then resumes clean.
#                                  live = AUDIO-MASTER: voice always real-time, lips best-effort (~0.75s trail),
#                                  never pauses -- switch to it if the steady pause is worse than the lip trail.
# MUSETALK_SYNC_FALLBACK_S=10    # (steady) if no video markers within this, forward voice unsynced
# BOT_VAD_STOP_FALLBACK_SECS=600 # steady-mode screech fix: keep high so a render stall can't discard the partial audio buffer

# ---- Remote / WAN viewing (jitter + bitrate) -----------------------------
# For a far viewer the lag is the NETWORK, not the render. Make the video FIT the link:
# a small frame (MUSETALK_SIZE above) + a bounded send bitrate, then a modest jitter buffer.
# WEBRTC_VIDEO_BITRATE_MAX  ceiling for aiortc's VP8 encoder (bits/sec). The stock 1.5M
#               ceiling overshoots a jittery consumer link -> the avatar trails the voice.
#               ~600k suits a 320px face. Set 0 to leave aiortc's defaults untouched.
# WEBRTC_VIDEO_BITRATE      start-point bitrate (default 500000); REMB adapts within the band.
# WEBRTC_VIDEO_BITRATE_MIN  floor (default 120000); below aiortc's stock 250k so a bandwidth
#               dip degrades gracefully instead of freezing.
# CLIENT_JITTER_BUFFER_MS   receive-side buffer (default 400; 0 = off). Once the stream fits
#               the link this can be SMALL (~250) -> less lip-lag. Bigger = smoother but the
#               avatar trails further behind the voice.
# WEBRTC_VIDEO_BITRATE_MAX=600000
# WEBRTC_VIDEO_BITRATE=500000
# WEBRTC_VIDEO_BITRATE_MIN=120000
# CLIENT_JITTER_BUFFER_MS=250
# WEBRTC_ICE_SUBNET=100.64.0.0/10  # pin WebRTC ICE to the Tailscale interface (fixes intermittent remote mic); 0 = off
